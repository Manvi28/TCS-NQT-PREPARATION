#include <iostream>
#include <vector>
#include <climits>
#include <algorithm>
using namespace std;

int minSubArrayLen(int target, vector<int>& nums) {

    int i = 0;
    int j = 0;
    int sum = 0;
    int mn = INT_MAX;

    while(j < nums.size()) {

        sum += nums[j];

        while(sum >= target) {

            mn = min(mn, j - i + 1);
            sum -= nums[i];
            i++;
        }

        j++;
    }

    if(mn == INT_MAX)
        return 0;

    return mn;
}

int main() {

    int n;
    cin >> n;

    vector<int> nums(n);

    for(int i = 0; i < n; i++) {
        cin >> nums[i];
    }

    int target;
    cin >> target;

    cout << minSubArrayLen(target, nums);

    return 0;
}
