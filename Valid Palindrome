#include <iostream>
#include <string>
#include <cctype>
using namespace std;

bool isPalindrome(string s) {

    string filtered;

    for(char c : s) {
        if(isalnum(c)) {
            filtered += tolower(c);
        }
    }

    int left = 0;
    int right = filtered.size() - 1;

    while(left < right) {

        if(filtered[left] != filtered[right]) {
            return false;
        }

        left++;
        right--;
    }

    return true;
}

int main() {

    string s;
    getline(cin, s);

    if(isPalindrome(s))
        cout << "true";
    else
        cout << "false";

    return 0;
}
