#include <iostream>
#include <vector>
using namespace std;

string longestCommonPrefix(vector<string>& strs) {

    string ans = "";

    for(int i = 0; i < strs[0].length(); i++) {

        char ch = strs[0][i];
        bool flag = true;

        for(int j = 1; j < strs.size(); j++) {

            if(i >= strs[j].size() || strs[j][i] != ch) {
                flag = false;
                break;
            }
        }

        if(flag == false) {
            break;
        }
        else {
            ans.push_back(ch);
        }
    }

    return ans;
}

int main() {

    int n;
    cin >> n;

    vector<string> strs(n);

    for(int i = 0; i < n; i++) {
        cin >> strs[i];
    }

    string result = longestCommonPrefix(strs);

    cout << result;

    return 0;
}
