#include <iostream>
#include <string>
using namespace std;

int strStr(string haystack, string needle) {

    int n = needle.length();
    int m = haystack.length();

    int i = 0;
    int j = 0;

    while(i < m) {

        if(haystack[i] == needle[j]) {

            if(j == n - 1) {
                return i - n + 1;
            }

            i++;
            j++;

        } 
        else {

            i = i - j + 1;
            j = 0;
        }
    }

    return -1;
}

int main() {

    string haystack, needle;

    cin >> haystack;
    cin >> needle;

    int ans = strStr(haystack, needle);

    cout << ans;

    return 0;
}
