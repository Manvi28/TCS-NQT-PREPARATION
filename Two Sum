#include <iostream>
#include <vector>
using namespace std;

vector<int> twoSum(vector<int>& nums, int target) {

    vector<int> ans;

    for(int i = 0; i < nums.size(); i++) {

        for(int j = i + 1; j < nums.size(); j++) {

            if(nums[i] + nums[j] == target) {

                ans.push_back(i);
                ans.push_back(j);

                return ans;
            }
        }
    }

    return ans;
}

int main() {

    int n;
    cin >> n;

    vector<int> nums(n);

    for(int i = 0; i < n; i++) {
        cin >> nums[i];
    }

    int target;
    cin >> target;

    vector<int> result = twoSum(nums, target);

    if(result.size() == 2) {
        cout << result[0] << " " << result[1];
    }
    else {
        cout << "No pair found";
    }

    return 0;
}
