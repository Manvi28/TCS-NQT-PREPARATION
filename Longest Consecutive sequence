#include <iostream>
#include <vector>
#include <unordered_set>
#include <algorithm>
using namespace std;

int longestConsecutive(vector<int>& nums) {

    if(nums.empty())
        return 0;

    unordered_set<int> s(nums.begin(), nums.end());

    int maxLen = 0;

    for(int num : s) {

        // Start only if num is the beginning of a sequence
        if(!s.count(num - 1)) {

            int curr = num;
            int streak = 1;

            while(s.count(curr + 1)) {
                curr++;
                streak++;
            }

            maxLen = max(maxLen, streak);
        }
    }

    return maxLen;
}

int main() {

    int n;
    cin >> n;

    vector<int> nums(n);

    for(int i = 0; i < n; i++) {
        cin >> nums[i];
    }

    cout << longestConsecutive(nums);

    return 0;
}
