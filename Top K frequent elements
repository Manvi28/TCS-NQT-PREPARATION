#include <iostream>
#include <vector>
#include <unordered_map>
#include <queue>
using namespace std;

vector<int> topKFrequent(vector<int>& nums, int k) {

    unordered_map<int, int> mp;

    // Count frequency
    for(int x : nums)
        mp[x]++;

    // Max Heap (frequency, element)
    priority_queue<pair<int, int>> pq;

    for(auto x : mp)
        pq.push({x.second, x.first});

    vector<int> ans;

    while(k--) {
        ans.push_back(pq.top().second);
        pq.pop();
    }

    return ans;
}

int main() {

    int n;
    cin >> n;

    vector<int> nums(n);

    for(int i = 0; i < n; i++) {
        cin >> nums[i];
    }

    int k;
    cin >> k;

    vector<int> ans = topKFrequent(nums, k);

    for(int x : ans) {
        cout << x << " ";
    }

    return 0;
}
