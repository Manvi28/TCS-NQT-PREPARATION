#include <iostream>
#include <vector>
using namespace std;

void moveZeroes(vector<int>& nums) {

    int i = 0;
    int j = 0;

    while(j < nums.size()) {

        if(nums[j] != 0) {
            swap(nums[i], nums[j]);
            i++;
        }

        j++;
    }
}

int main() {

    int n;
    cin >> n;

    vector<int> nums(n);

    for(int i = 0; i < n; i++) {
        cin >> nums[i];
    }

    moveZeroes(nums);

    for(int i = 0; i < n; i++) {
        cout << nums[i] << " ";
    }

    return 0;
}
