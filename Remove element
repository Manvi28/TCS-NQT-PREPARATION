#include <iostream>
#include <vector>
using namespace std;

int removeElement(vector<int>& nums, int val) {
    int j = 0;

    for(int i = 0; i < nums.size(); i++) {
        if(nums[i] != val) {
            nums[j] = nums[i];
            j++;
        }
    }

    return j;
}

int main() {
    int n;
    cin >> n;

    vector<int> nums(n);

    for(int i = 0; i < n; i++) {
        cin >> nums[i];
    }

    int val;
    cin >> val;

    int newLength = removeElement(nums, val);

    cout << newLength << endl;

    for(int i = 0; i < newLength; i++) {
        cout << nums[i] << " ";
    }

    return 0;
}
