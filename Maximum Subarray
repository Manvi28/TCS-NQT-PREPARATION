#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

int maxSubArray(vector<int>& nums) {

    int res = nums[0];
    int total = 0;

    for(int n : nums) {

        if(total < 0) {
            total = 0;
        }

        total += n;

        res = max(res, total);
    }

    return res;
}

int main() {

    int n;
    cin >> n;

    vector<int> nums(n);

    for(int i = 0; i < n; i++) {
        cin >> nums[i];
    }

    cout << maxSubArray(nums);

    return 0;
}
