#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

int area(int l, int r, vector<int>& height) {
    return min(height[l], height[r]) * (r - l);
}

int maxArea(vector<int>& height) {

    int n = height.size();

    int l = 0;
    int r = n - 1;

    int A = 0;

    while(l < r) {

        A = max(A, area(l, r, height));

        if(height[r] < height[l])
            r--;
        else
            l++;
    }

    return A;
}

int main() {

    int n;
    cin >> n;

    vector<int> height(n);

    for(int i = 0; i < n; i++) {
        cin >> height[i];
    }

    cout << maxArea(height);

    return 0;
}
