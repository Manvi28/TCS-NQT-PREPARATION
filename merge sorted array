#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

void merge(vector<int>& nums1, int m, vector<int>& nums2, int n) {

    for(int j = 0, i = m; j < n; j++) {
        nums1[i] = nums2[j];
        i++;
    }

    sort(nums1.begin(), nums1.end());
}

int main() {

    int m, n;

    cin >> m;

    vector<int> nums1(m + n);

    // Read only the first m valid elements
    for(int i = 0; i < m; i++) {
        cin >> nums1[i];
    }

    cin >> n;

    vector<int> nums2(n);

    for(int i = 0; i < n; i++) {
        cin >> nums2[i];
    }

    merge(nums1, m, nums2, n);

    for(int i = 0; i < m + n; i++) {
        cout << nums1[i] << " ";
    }

    return 0;
}
