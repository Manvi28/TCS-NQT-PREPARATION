#include <iostream>
#include <vector>
#include <set>
using namespace std;

bool containsDuplicate(vector<int>& nums) {

    set<int> s(nums.begin(), nums.end());

    if(s.size() == nums.size())
        return false;
    else
        return true;
}

int main() {

    int n;
    cin >> n;

    vector<int> nums(n);

    for(int i = 0; i < n; i++) {
        cin >> nums[i];
    }

    if(containsDuplicate(nums))
        cout << "true";
    else
        cout << "false";

    return 0;
}
