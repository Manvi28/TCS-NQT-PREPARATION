#include <iostream>
#include <string>
using namespace std;

int lengthOfLastWord(string s) {

    int n = s.length();
    int j = n - 1;

    // Skip trailing spaces
    while(j >= 0 && s[j] == ' ') {
        j--;
    }

    int cnt = 0;

    // Count characters of last word
    while(j >= 0 && s[j] != ' ') {
        cnt++;
        j--;
    }

    return cnt;
}

int main() {

    string s;

    getline(cin, s);

    int result = lengthOfLastWord(s);

    cout << result;

    return 0;
}
